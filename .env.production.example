# Copie estes nomes para as variaveis de ambiente da hospedagem.
# Nao coloque valores reais em arquivos versionados.

NODE_ENV=production
PORT=3000

# URLs publicas reais depois do deploy.
FRONTEND_URL=https://seudominio.com.br
BACKEND_URL=https://seudominio.com.br

# Banco Neon/PostgreSQL.
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require

# Mercado Pago da aplicacao real.
MERCADO_PAGO_PUBLIC_KEY=APP_USR-sua-public-key
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-seu-access-token
MERCADO_PAGO_WEBHOOK_SECRET=gere-um-segredo-forte-para-o-webhook

# Gestor e sessoes.
ADMIN_PASSWORD=troque-por-uma-senha-forte
SESSION_SECRET=gere-uma-chave-aleatoria-com-mais-de-32-caracteres

# Pedidos Pix/online pendentes expiram automaticamente.
PIX_PENDING_EXPIRATION_MINUTES=60

# Twilio e opcional neste projeto, pois o login por telefone nao exige SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_VERIFY_FRIENDLY_NAME=Encanto do Vale
TWILIO_VERIFY_TEMPLATE_SID=
