MERCADO_PAGO_PUBLIC_KEY=
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require

# Autenticação do gestor e assinatura das sessões.
ADMIN_PASSWORD=
SESSION_SECRET=

# Twilio Verify para códigos por SMS ou WhatsApp.
# O Service SID começa com VA. Content SID (HX) não funciona neste campo.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_VERIFY_FRIENDLY_NAME=Encanto do Vale
# Opcional: template aprovado da Twilio para personalizar exatamente o SMS.
TWILIO_VERIFY_TEMPLATE_SID=

# Persistência local substituível por banco de dados.
ORDERS_FILE=backend/data/orders.json
USERS_FILE=backend/data/users.json

# Tempo para expirar Pix/pagamento online pendente.
PIX_PENDING_EXPIRATION_MINUTES=60
